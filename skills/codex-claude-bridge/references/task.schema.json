{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "codex-claude-task-v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "run_id", "task_id", "correlation_id", "attempt_id",
    "created_at", "project_name", "workspace_root", "objective", "input_files",
    "allowed_roots", "authority", "no_touch_rules", "done_criteria",
    "required_return_fields", "model_request", "max_rounds", "round_number"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "run_id": {"type": "string", "minLength": 1},
    "task_id": {"type": "string", "minLength": 1},
    "correlation_id": {"type": "string", "minLength": 1},
    "attempt_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "project_name": {"type": "string", "minLength": 1},
    "workspace_root": {"type": "string", "minLength": 1},
    "objective": {"type": "string", "minLength": 1},
    "input_files": {"type": "array", "items": {"type": "object", "required": ["path", "sha256", "size_bytes"]}},
    "allowed_roots": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "authority": {"type": "object", "required": ["mode", "permission_mode", "allowed_tools"]},
    "no_touch_rules": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "done_criteria": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "required_return_fields": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "model_request": {"type": "object", "required": ["provider", "model", "max_budget_usd"]},
    "max_rounds": {"type": "integer", "minimum": 1, "maximum": 4},
    "round_number": {"type": "integer", "minimum": 1, "maximum": 4}
  }
}
