{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "codex-claude-receipt-v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "run_id", "task_id", "correlation_id", "attempt_id", "status",
    "summary", "decisions", "deliverable", "evidence", "files_needed", "files_touched",
    "blockers", "owner_button_needed", "commander_approval_needed", "codex_next_action",
    "confidence", "go_back_to_codex", "completed_at"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "run_id": {"type": "string", "minLength": 1},
    "task_id": {"type": "string", "minLength": 1},
    "correlation_id": {"type": "string", "minLength": 1},
    "attempt_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["succeeded", "blocked", "failed"]},
    "summary": {"type": "string", "minLength": 1},
    "decisions": {"type": "array", "items": {"type": "string"}},
    "deliverable": {"type": "string"},
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "ref"],
        "properties": {
          "claim": {"type": "string", "minLength": 1},
          "ref": {"type": "string", "minLength": 1}
        }
      }
    },
    "files_needed": {"type": "array", "items": {"type": "string"}},
    "files_touched": {"type": "array", "maxItems": 0, "items": {"type": "string"}},
    "blockers": {"type": "array", "items": {"type": "string"}},
    "owner_button_needed": {"type": "boolean"},
    "commander_approval_needed": {"type": "boolean"},
    "codex_next_action": {"type": "string", "minLength": 1},
    "confidence": {"type": "number", "minimum": 0, "maximum": 100},
    "go_back_to_codex": {"type": "boolean"},
    "completed_at": {"type": "string", "format": "date-time"}
  }
}
